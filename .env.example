# ───── Runtime ─────
NODE_ENV=development
PORT=3002
SERVICE_NAME=order-service
LOG_LEVEL=info

# ───── Database (Prisma / PostgreSQL) ─────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_service?schema=public

# ───── Auth (JWT) ─────
# MUST be identical to auth-service's JWT_ACCESS_SECRET, otherwise access
# tokens minted by auth-service will fail verification here.
JWT_ACCESS_SECRET=change-me-shared-access-secret

# ───── Internal service-to-service (checkout → product-service) ─────
# product-service base URL, already including its /api/v1 prefix.
PRODUCT_SERVICE_URL=http://localhost:3001/api/v1
# Shared secret sent as `x-internal-api-key`. MUST match product-service's.
INTERNAL_API_KEY=change-me-shared-internal-key

# ───── HTTP ─────
# Comma-separated list, or "*" for all
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
BODY_LIMIT=1mb

# ───── Rate Limiting ─────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
